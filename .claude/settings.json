{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(hugo:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git restore:*)",
      "Read(./**)",
      "Edit(./content/**)",
      "Edit(./assets/**)",
      "Edit(./layouts/**)",
      "Edit(./config/**)",
      "Edit(./static/**)",
      "Edit(./data/**)",
      "Write(./content/**)",
      "Write(./assets/**)",
      "Write(./layouts/**)",
      "Write(./config/**)",
      "Write(./static/**)",
      "Write(./data/**)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./.dev.vars)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Bash(sudo:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/pre-push-build.sh",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
