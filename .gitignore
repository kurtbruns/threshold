.DS_Store
Thumbs.db

# Hugo build output & caches (all regenerated by a build)
public/
resources/_gen/
.hugo_build.lock

# Claude Code: the .claude/ directory IS checked in (it ships the project
# context). Only personal/transient bits are ignored.
.claude/settings.local.json
.claude/worktrees/

# Ignore the Claude Code context used to maintain the starter kit.
# See .claude/maintainer/README.md for how this frame works.
CLAUDE.local.md

# Version-manager pin files. The canonical Hugo pin lives in
# hugo.yaml module.hugoVersion.min (see scripts/hugo-version.sh).
# Drop one of these locally if your tool needs it, but it isn't source of truth.
.tool-versions
mise.toml
mise.local.toml
.hvm

# Secrets / local env (never commit)
.env
.env.*
.dev.vars
*.pem
*.key
